# Copy this file to .env.local and fill in your values
# (Next.js loads .env.local automatically)

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# UUID of the provider row in your Supabase providers table (used by the booking slot picker)
NEXT_PUBLIC_PROVIDER_ID=00000000-0000-0000-0000-000000000001
