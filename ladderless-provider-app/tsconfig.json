{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/core/*": ["src/core/*"],
      "@/features/*": ["src/features/*"],
      "@/ui/*": ["src/core/ui-components/*"],
      "@/jobs/*": ["src/core/jobs/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
